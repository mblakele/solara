# VUE / EM1 metrics credentials (required for NBC predictions)
VUE_USERNAME=your_vue_username
VUE_PASSWORD=your_vue_password

# === Load Management Configuration ===

# Enable/disable automatic load management background loop. Accepts True,
# False, or a time range in HH:MM-HH:MM 24-hour format (e.g., "06:45-15:00").
# When a time range is given, load management is active only during that window
# (inclusive start, exclusive end) in the device timezone.
LOAD_MANAGE_ENABLED=False

# Interval in seconds between automatic load management cycles
LOAD_MANAGE_INTERVAL_SECS=30

# Dry-run mode: actions are calculated and logged but NOT executed.
# Use this to verify configuration before enabling real control.
LOAD_MANAGE_DRY_RUN=False

# API key for /api/v1/load/manage endpoint auth (empty = disabled)
LOAD_MANAGE_API_KEY=

# Plug controller type: "real" (aiohomekit) or "stub" (in-memory mock)
# When both HomeKit and VOCOlinc plugs are configured, a composite controller
# is used automatically. This setting controls the HomeKit backend type.
LOAD_PLUG_CONTROLLER=stub

# === Device Configuration ===
# Device-specific settings (timezone, smart meter, plugs, Tesla vehicle) are
# now managed in devices.json. Copy devices.json.example to devices.json and
# edit it for your setup. That file is git-ignored and never committed.

# === VOCOlinc Credentials ===
# Required if using VOCOlinc plugs (credentials stay in .env as secrets)
VOCOLINC_USERNAME=
VOCOLINC_PASSWORD=

# Tesla controller type: "real" (tesla-fleet-api) or "stub" (in-memory mock)
LOAD_TESLA_CONTROLLER=stub

# === Tesla Fleet API Configuration (required for real Tesla controller) ===
# Get these from https://developer.tesla.com/
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REGION=na

# Path to Tesla Fleet API private key file (PEM format). Required for
# vehicle commands like set_amps. Without this, auth works but commands fail.
TESLA_PRIVATE_KEY_PATH=
