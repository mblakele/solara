modules = ["python-3.12", "web"]
run = "gunicorn app:app --bind 0.0.0.0:8000"
# replit guesses wrong about decouple, humps
disableGuessImports = true

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "gunicorn app:app"]

[[ports]]
localPort = 8000
externalPort = 8000

[packager]
language = "python3"

[auth]
pageEnabled = false
buttonEnabled = false

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Flask App"

[[workflows.workflow]]
name = "Run Flask App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv run python app.py"
waitForPort = 8000

[userenv]

[userenv.shared]
UV_PROJECT_ENVIRONMENT = ".venv"
